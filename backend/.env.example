# Server
PORT=5005

# Local Docker PostgreSQL:
# USE_SQLITE=false
# DATABASE_URL=postgresql://sinhto:sinhto@localhost:5432/sinhto

# Local dev mac dinh (khong can cai gi):
USE_SQLITE=true

# Supabase: Project Settings → Database → Connection string → URI
# Dùng "Session pooler" (port 5432) hoặc "Transaction pooler" (port 6543) cho backend Node.js
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# SSL tự bật khi host chứa supabase.co

# Production managed Postgres (Railway, RDS, ...)
# PGSSLMODE=require

# Connection pool size (optional, default 20)
# PG_POOL_MAX=20

# SQLite migration source (only for migrate-sqlite-to-pg.js)
# SQLITE_PATH=../data/database.sqlite
